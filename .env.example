# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_ID=

# ─── Database (Neon PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=

# ─── Auth (NextAuth v5) ────────────────────────────────────────────────────
JWT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_ADDRESS=DreamForgeX <noreply@dreamforgex.ai>

# ─── Stripe Payments ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── AI Providers ──────────────────────────────────────────────────────────
GROK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
STABILITY_API_KEY=
REPLICATE_API_TOKEN=

# Built-in Forge (legacy provider)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── Cloudflare R2 Storage ─────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=dreamforge-assets
R2_PUBLIC_URL=

# ─── Legacy (can be removed if not using Manus OAuth) ──────────────────────
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_APP_ID=
